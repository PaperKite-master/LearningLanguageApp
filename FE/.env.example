# --- Chạy dev (`npm run dev`) ---
# Backend mặc định: http://localhost:4000. Đổi nếu API chạy chỗ khác.
# VITE_DEV_API_PROXY=http://localhost:4000

# --- Build production (`npm run build`) ---
# Để trống: axios dùng prefix /api (proxy dev hoặc nginx trong Docker).
# Khi deploy FE tách domain với BE: URL gốc của API, không có / ở cuối.
# Ví dụ: https://your-api.onrender.com
# VITE_API_BASE_URL=https://your-api.onrender.com
