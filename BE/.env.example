NODE_ENV=development
PORT=4000

# Supabase Auth
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# CORS — origin FE (Vercel), phân tách bằng dấu phẩy, không / ở cuối
CORS_ORIGIN="http://localhost:3000,https://hina-japanese-app.vercel.app"

# For local docker postgres (see docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learning_language_app?schema=public"

# Optional (if you later connect to Supabase hosted Postgres)
# Supabase recommended setup with Prisma:
# - DATABASE_URL: pooler/transaction URL for runtime
# - DIRECT_URL: direct connection for migrations
#
# Example using Transaction pooler (IPv4, port 6543) - add pgbouncer=true:
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Example direct connection (port 5432):
# DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"
